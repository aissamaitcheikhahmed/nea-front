# Copy to .env or .env.local for LOCAL dev only. Never commit real values.
# IMPORTANT: Deployed Vercel /api/* does NOT read this file. Add secrets in Vercel
# (Production + Preview), then Redeploy — especially MONGODB_URI.
# Large product images use client-side Blob upload (no 4.5 MB serverless body limit).

# Vercel Blob — add in Vercel dashboard AND here for vercel dev
BLOB_READ_WRITE_TOKEN=

# MongoDB Atlas — add in Vercel dashboard AND here for vercel dev (password: URL-encode @ as %40)
MONGODB_URI=

# Same random string on server and client (admin POST + Vite build)
ADMIN_API_SECRET=
VITE_ADMIN_API_SECRET=

# Local dev only: while `vercel dev` runs on :3000, point the admin form at the API directly (avoids Vite proxy reset on large uploads)
# VITE_API_ORIGIN=http://localhost:3000

# Optional overrides (defaults in api/products.js)
# MONGODB_DB=neaevents
# MONGODB_PRODUCTS_COLLECTION=products
